# Copy to .env and fill in to enable live mode. The app runs fully without any of these
# (mock/template mode) — see README "Setup & Run".

# Enables live Claude generation instead of the deterministic template fallback.
ANTHROPIC_API_KEY=

# Optional — overrides the default model id in revops_copilot/config.py.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — enables Opik LLM call tracing (latency/tokens/success-failure).
# App runs identically, just without traces, if unset.
OPIK_API_KEY=
